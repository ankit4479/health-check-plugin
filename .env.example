# health-check-plugin — environment variables
# Copy to .env and fill in. .env is gitignored; never commit real secrets.
# Each var is referenced BY NAME from health-check.config.json (urlEnv / webhookEnv /
# repoEnv / tokenEnv / headersFromEnv), so you can rename them to suit your project.

# ── Data sources (postgres collectors) ──────────────────────────────
# Referenced by config.dataSources[*].urlEnv
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Delivery channel ────────────────────────────────────────────────
# Referenced by config.channel.webhookEnv (when channel.type = "discord")
HEALTH_DISCORD_WEBHOOK_URL=

# ── GitHub issue creation ───────────────────────────────────────────
# Referenced by config.github.repoEnv / tokenEnv
HEALTH_GITHUB_REPO=owner/repo
# Optional: a PAT with `repo` scope. If omitted, the local `gh` CLI is used instead.
GITHUB_TOKEN=

# ── Config path override (optional) ─────────────────────────────────
# HEALTH_CHECK_CONFIG=./health-check.config.json
